RewriteEngine On
RewriteBase /

# Corta cualquier bucle: si la petición ya es index.php, no la vuelvas a reescribir
RewriteCond %{REQUEST_URI} !^/index\.php$

# Si el fichero o directorio solicitado no existe físicamente,
# se envía todo a index.php (front controller)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]
